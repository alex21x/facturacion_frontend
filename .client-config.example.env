# ===== CONFIGURACION DE RED Y PUERTOS =====
# DOCKER_BIND_HOST: Dirección donde escuchan los servicios
#   127.0.0.1 = Solo acceso local en esta PC (seguro)
#   0.0.0.0   = Acceso desde otras PCs de la red (requiere firewall abierto en puerto)
DOCKER_BIND_HOST=127.0.0.1

# Puertos de exposición (no modificar a menos que haya conflictos)
BACKEND_PORT=8000
FRONTEND_PORT=5173
ADMIN_PORT=5174
PGADMIN_PORT=5050

# URL que el frontend usa para conectar con el backend
# Si la instalacion queda en modo LAN, puede dejarse vacio para autodetectar
# la IP/hostname desde donde accede cada PC cliente.
VITE_API_BASE_URL=http://127.0.0.1:8000

# ===== CONFIGURACION DE PROYECTO Y RAMAS =====
FRONTEND_BRANCH=main
BACKEND_BRANCH=main
COMPOSE_PROJECT_NAME=facturacion_local

# ===== CONFIGURACION DE BASE DE DATOS =====
POSTGRES_DB=facturacion_v2
POSTGRES_USER=facturacion
POSTGRES_PASSWORD=facturacion
PGADMIN_DEFAULT_EMAIL=admin@facturacion.local
PGADMIN_DEFAULT_PASSWORD=Admin123!

# Ruta al dump SQL inicial para poblar la BD
BOOTSTRAP_SQL_PATH=..\facturacion_backend\facturacion_v2_export_utf8_clean_20260418_105235.sql

# Script SQL para limpiar tablas transaccionales/operacionales
TRANSACTIONAL_CLEANUP_SQL_PATH=..\facturacion_backend\database\sql\clean_transactional_operational.sql
CLEAN_TRANSACTIONAL_ON_RESTORE=true

# ===== CONFIGURACION DE INSTALACION =====
RUN_MIGRATIONS=true
RUN_SEED_ON_INSTALL=false